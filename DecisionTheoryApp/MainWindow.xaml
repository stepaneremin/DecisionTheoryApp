<Window x:Class="DecisionTheoryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DecisionTheoryApp"
        mc:Ignorable="d"
        Title="Decision Theory App" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F9">

    <Window.Resources>
        <LinearGradientBrush x:Key="PinkGradient" EndPoint="1,0.5" StartPoint="0,0.5">
            <GradientStop Color="#f4c3d9" Offset="0"/>
            <GradientStop Color="#e9bbec" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GreenGradient" EndPoint="1,0.5" StartPoint="0,0.5">
            <GradientStop Color="#d7f6bb" Offset="0"/>
            <GradientStop Color="#b8e09b" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MethodButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="MinHeight" Value="100"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#a01c46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e9bbec"/>
                    <Setter Property="Foreground" Value="#643f61"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#a01c46"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#643f61" Padding="20" CornerRadius="0,0,20,20">
            <TextBlock Text="Система поддержки принятия решений" 
                      FontSize="24" FontWeight="SemiBold" 
                      Foreground="White"
                      HorizontalAlignment="Center"
                      TextWrapping="Wrap"
                      FontFamily="Segoe UI"/>
        </Border>

        <!-- Кнопки выбора метода -->
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">

            <Button Content="Метод анализа иерархий" 
                    Style="{StaticResource MethodButtonStyle}"
                    Background="{StaticResource PinkGradient}"
                    Click="AHPButton_Click" Width="262"/>

            <Button Content="Метод главного критерия" 
                    Style="{StaticResource MethodButtonStyle}"
                    Background="{StaticResource GreenGradient}"
                    Click="MainCriterionButton_Click" Width="262"/>
        </StackPanel>
    </Grid>
</Window>