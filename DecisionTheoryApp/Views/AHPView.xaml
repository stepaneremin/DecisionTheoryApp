<Window x:Class="DecisionTheoryApp.Views.AHPView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AHP"
        Height="500"
        Width="700">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>

            <Button Content="Добавить критерий"
                    Click="AddCriterion"/>

            <Button Content="Добавить альтернативу"
                    Click="AddAlternative"/>

            <Button Content="Создать матрицу"
                    Click="CreateMatrix"/>

            <Button Content="Рассчитать"
                    Click="Calculate"/>

            <Button Content="Сохранить JSON"
                    Click="SaveProject"/>

            <Button Content="Загрузить JSON"
                    Click="LoadProject"/>

            <Button Content="Создать отчет"
                    Click="CreateReport"/>

            <ListBox x:Name="CriteriaList"/>
            <ListBox x:Name="AlternativeList"/>

        </StackPanel>

		<TabControl Grid.Column="1">

			<TabItem Header="Матрица критериев">

				<DataGrid x:Name="MatrixGrid"
						  AutoGenerateColumns="True"/>

			</TabItem>

			<TabItem Header="Матрицы альтернатив">

				<DataGrid x:Name="AlternativeMatrixGrid"
						  AutoGenerateColumns="True"/>

			</TabItem>

		</TabControl>

    </Grid>

</Window>