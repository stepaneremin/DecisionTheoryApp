<Window x:Class="DecisionTheoryApp.Views.AHPView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DecisionTheoryApp.Converters"
        Title="Метод анализа иерархий"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        FontFamily="Segoe UI">
    <Window.Resources>
        <converters:NullToEmptyConverter x:Key="NullToEmptyConverter"/>
        <Style x:Key="CenteredCellStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValidatedEditingStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="Background" Value="#ffe0e0"/>
                    <Setter Property="Foreground" Value="#c62828"/>
                    <Setter Property="ToolTip" Value="Введите целое число от 1 до 9 (шкала Саати)"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#f4c3d9"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e6e6e6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#cccccc"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Background="#FFFFFF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Border Grid.Column="0" Background="#fafafa" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0">
        <StackPanel Margin="10">
            <TextBlock Text="Управление" FontWeight="SemiBold" FontSize="14" Foreground="#643f61" Margin="0,0,0,10"/>

            <!-- Поле для нового критерия -->
            <TextBox Text="{Binding NewCriterionName, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5" Padding="5"/>
            <Button Content="➕ Добавить критерий" 
                    Command="{Binding AddCriterionCommand}"
                    Style="{StaticResource RoundedButton}"
                    Background="#d7f6bb" Foreground="#53723c"
                    Margin="0,5" Padding="5"/>

            <!-- Поле для новой альтернативы -->
            <TextBox Text="{Binding NewAlternativeName, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5" Padding="5"/>
            <Button Content="➕ Добавить альтернативу" 
                    Command="{Binding AddAlternativeCommand}"
                    Style="{StaticResource RoundedButton}"
                    Background="#d7f6bb" Foreground="#53723c"
                    Margin="0,5" Padding="5"/>
            <!--
            <Button Content="📊 Создать матрицу критериев" 
                    Command="{Binding CreateMatrixCommand}" 
                    Padding="5"/>

            <Button Content="📈 Создать матрицы альтернатив" 
                    Command="{Binding CreateAlternativeMatricesCommand}" 
                    Margin="0,5" Padding="5"/>
            -->

            <Button Content="🗑️ Очистить проект"
                    Command="{Binding ClearProjectCommand}"
                    Focusable="False"
                    Margin="0,5" Padding="5"
                    Style="{StaticResource RoundedButton}"
                    Background="#ffebee" Foreground="#c62828"/>

            <Button Content="🧮 Рассчитать" 
                    Command="{Binding CalculateCommand}"
                    Style="{StaticResource RoundedButton}"
                    Margin="0,5" Padding="5"
                    Background="#d7f6bb" Foreground="#53723c"
                    FontWeight="SemiBold"/>

            <Separator Margin="0,10" Background="#e0e0e0"/>

            <Button Content="💾 Сохранить проект" 
                    Command="{Binding SaveProjectCommand}"
                    Style="{StaticResource RoundedButton}"
                    Background="#f0f0f0" Foreground="#4A4A4A"
                    Margin="0,5" Padding="5"/>

            <Button Content="📂 Загрузить проект" 
                    Command="{Binding LoadProjectCommand}"
                    Style="{StaticResource RoundedButton}"
                    Background="#f0f0f0" Foreground="#4A4A4A"
                    Margin="0,5" Padding="5"/>

            <Button Content="📄 Создать отчет" 
                    Command="{Binding CreateReportCommand}"
                    Style="{StaticResource RoundedButton}"
                    Margin="0,5" Padding="5"
                    Background="#e9bbec" Foreground="#643f61"/>

            <Button Content="❓ Справка"
                    Click="HelpButton_Click"
                    Focusable="False"
                    Margin="0,5" Padding="5"
                    Style="{StaticResource RoundedButton}"
                    Background="#eaf4fb" Foreground="#1a5276"/>

            <Separator Margin="0,10" Background="#e0e0e0"/>

            <TextBlock Text="Критерии:" FontWeight="SemiBold" Foreground="#4A4A4A" Margin="0,5"/>
            <ListBox ItemsSource="{Binding Criteria}" Height="100" Margin="0,0,0,10"
                     HorizontalContentAlignment="Stretch"
                     BorderBrush="#e0e0e0"
                     MouseDoubleClick="CriteriaListBox_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CriterionTextBlock"
                                       Grid.Column="0" Text="{Binding Name}"
                                       VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox x:Name="CriterionTextBox"
                                     Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                                     VerticalAlignment="Center" Margin="3,1,3,1"
                                     Visibility="Collapsed"
                                     LostFocus="CriterionTextBox_LostFocus"
                                     KeyDown="RenameTextBox_KeyDown"/>
                            <Button Grid.Column="1"
                                    Content="❌"
                                    Width="14" Height="14"
                                    FontSize="10"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,5,0"
                                    HorizontalContentAlignment="Right"
                                    Focusable="False"
                                    Command="{Binding DataContext.RemoveCriterionCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

                <TextBlock Text="Альтернативы:" FontWeight="SemiBold" Foreground="#4A4A4A" Margin="0,5"/>
                <ListBox ItemsSource="{Binding Alternatives}" Height="100" Margin="0,0,0,10"
         HorizontalContentAlignment="Stretch"
         BorderBrush="#e0e0e0"
         MouseDoubleClick="AlternativesListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="AlternativeTextBlock"
                           Grid.Column="0" Text="{Binding Name}"
                           VerticalAlignment="Center" Margin="5,0,5,0"
                           Foreground="#4A4A4A"/>
                                <TextBox x:Name="AlternativeTextBox"
                         Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                         VerticalAlignment="Center" Margin="3,1,3,1"
                         Visibility="Collapsed"
                         LostFocus="AlternativeTextBox_LostFocus"
                         KeyDown="RenameTextBox_KeyDown"/>
                                <Button Grid.Column="1"
                        Content="❌"
                        Width="14" Height="14"
                        FontSize="10"
                        Background="Transparent"
                        Foreground="#888888"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0,0,5,0"
                        HorizontalContentAlignment="Right"
                        Focusable="False"
                        Command="{Binding DataContext.RemoveAlternativeCommand,
                                  RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </Border>

        <!-- Правая панель -->
        <TabControl Grid.Column="1" Margin="10">
            <TabItem Header="Матрица критериев">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <DataGrid x:Name="CriteriaMatrixGrid"
                              ItemsSource="{Binding CriteriaMatrixTable}"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserSortColumns="False"
                              AutoGeneratingColumn="CriteriaMatrixGrid_AutoGeneratingColumn"
                              BeginningEdit="MatrixGrid_BeginningEdit"
                              CellEditEnding="MatrixGrid_CellEditEnding"
                              Margin="5"
                               BorderBrush="#e0e0e0"
                               AlternatingRowBackground="#FFF9FC"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Матрицы альтернатив">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AlternativesItemsControl" ItemsSource="{Binding AlternativesMatricesTables}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="5" Background="White">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CriterionName}"
                                                   FontWeight="SemiBold" FontSize="14" Foreground="#643f61" Margin="0,0,0,10"/>
                                        <DataGrid ItemsSource="{Binding Table}"
                                                  Tag="{Binding CriterionName}"
                                                  AutoGenerateColumns="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserSortColumns="False"
                                                  AutoGeneratingColumn="AlternativesMatrixGrid_AutoGeneratingColumn"
                                                  BeginningEdit="MatrixGrid_BeginningEdit"
                                                  CellEditEnding="MatrixGrid_CellEditEnding"
                                                  Height="200"
                                                   BorderBrush="#e0e0e0"
                                                   AlternatingRowBackground="#FFF9FC"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Результаты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Текущий результат -->
                    <ScrollViewer Grid.Row="0" MaxHeight="200">
                        <StackPanel Margin="10,10,10,0">
                            <Border Background="#d7f6bb" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <TextBlock Text="{Binding ConsistencyMessage}" TextWrapping="Wrap" FontSize="13" Foreground="#53723c"/>
                            </Border>
                            <TextBlock Text="Последний расчёт:" FontWeight="SemiBold" Foreground="#643f61" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding Alternatives}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="#4A4A4A">
                                            <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <Run Text=": "/>
                                            <Run Text="{Binding Priority, StringFormat={}{0:P1}}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- История расчётов -->
                    <Border Grid.Row="1" Margin="10,8,10,10" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Заголовок истории -->
                            <Border Grid.Row="0" Background="#f4e9fb" CornerRadius="8,8,0,0" Padding="10,6">
                                <Grid>
                                    <TextBlock Text="История расчётов" FontWeight="SemiBold"
                                               Foreground="#643f61" VerticalAlignment="Center"/>
                                    <Button Content="🗑 Очистить историю"
                                            Command="{Binding ClearHistoryCommand}"
                                            HorizontalAlignment="Right"
                                            Focusable="False"
                                            Padding="8,3" BorderThickness="0"
                                            Background="#e9bbec" Foreground="#643f61"
                                            Cursor="Hand"/>
                                </Grid>
                            </Border>

                            <!-- Таблица истории — колонки строятся динамически в code-behind -->
                            <DataGrid x:Name="HistoryGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding CalculationHistory}"
                                      AlternatingRowBackground="#FFF9FC"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Width="36"
                                                        Binding="{Binding Number}"/>
                                    <DataGridTextColumn Header="Время" Width="70"
                                                        Binding="{Binding Time}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Заглушка когда история пуста -->
                            <TextBlock Grid.Row="1"
                                       Text="История пуста — выполните расчёт"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#aaa" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CalculationHistory.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>