<Window x:Class="DecisionTheoryApp.Views.MultiCriteriaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DecisionTheoryApp.Views"
        mc:Ignorable="d"
        Title="Метод главного критерия" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2c3e50" Padding="10">
            <TextBlock Text="Метод главного критерия" 
                      FontSize="18" FontWeight="Bold" Foreground="White"
                      HorizontalAlignment="Center"/>
        </Border>

        <!-- Центральная область с сообщением -->
        <Border Grid.Row="1" Background="#ecf0f1" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🚧" FontSize="72" TextAlignment="Center"/>
                <TextBlock Text="Метод главного критерия находится в разработке" 
                          FontSize="24" FontWeight="SemiBold" 
                          TextAlignment="Center" Margin="0,20,0,10"/>
                <TextBlock Text="Данный функционал будет доступен в следующих версиях приложения" 
                          FontSize="14" Foreground="#7f8c8d"
                          TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Кнопка закрытия -->
        <Border Grid.Row="2" Background="#bdc3c7" Padding="10">
            <Button Content="Закрыть" 
                    Width="100" Height="30"
                    HorizontalAlignment="Center"
                    Click="CloseButton_Click"/>
        </Border>
    </Grid>
</Window>